# Examples only. server.py reads the process environment; it does not load this file.
# Use independently generated values of at least 24 characters.
OPENBEXI_API_VIEWER_TOKEN=replace-with-a-random-viewer-token
OPENBEXI_API_ANALYST_TOKEN=replace-with-a-random-analyst-token
OPENBEXI_API_ADMIN_TOKEN=replace-with-a-random-administrator-token

# Optional. When omitted, a private stable key is generated under runtime/.
OPENBEXI_CURSOR_SECRET=replace-with-a-random-cursor-signing-secret
